Instance.new("UICorner", StatusLabel)

TweenService:Create(Main, TweenInfo.new(0.6, Enum.EasingStyle.Back), {
	Position = UDim2.new(0.5, -110, 0, 30)
}):Play()

-- LOGIC
local IsActive = false

local function toggle()
	IsActive = not IsActive
	
	if IsActive then
		StatusLabel.Text = "INSTANT E: ACTIVE"
		StatusLabel.TextColor3 = Color3.fromRGB(0,255,170)
	else
		StatusLabel.Text = "INSTANT E: OFF [Q]"
		StatusLabel.TextColor3 = Color3.fromRGB(255,70,70)
	end
end

UIS.InputBegan:Connect(function(i, p)
	if not p and i.KeyCode == Enum.KeyCode.Q then
		toggle()
	end
end)

