Instance.new("UICorner", Main).CornerRadius = UDim.new(0,14)

-- Sürüklenebilir panel
Main.Active = true
Main.Draggable = true

-- RGB Başlık
local TitleBG = Instance.new("Frame", Main)
TitleBG.Size = UDim2.new(1,0,0,40)
TitleBG.Position = UDim2.new(0,0,0,5)
Instance.new("UICorner", TitleBG).CornerRadius = UDim.new(0,12)

local Title = Instance.new("TextLabel", TitleBG)
Title.Size = UDim2.new(1,0,1,0)
Title.BackgroundTransparency = 1
Title.Text = "Script by kacow"
Title.TextColor3 = Color3.new(1,1,1)
Title.TextScaled = true
Title.Font = Enum.Font.GothamBlack

local colors = {
	Color3.fromRGB(255,0,0),
	Color3.fromRGB(255,150,0),
	Color3.fromRGB(0,255,0),
	Color3.fromRGB(0,255,255),
	Color3.fromRGB(0,0,255),
	Color3.fromRGB(255,0,255)
}

task.spawn(function()
	local i = 1
	while true do
		TweenService:Create(TitleBG, TweenInfo.new(0.4), {
			BackgroundColor3 = colors[i]
		}):Play()
		i += 1
		if i > #colors then i = 1 end
		task.wait(0.4)
	end
end)

