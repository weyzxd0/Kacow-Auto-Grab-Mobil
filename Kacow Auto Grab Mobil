local TweenService = game:GetService("TweenService")

local UI_Target = Player:WaitForChild("PlayerGui")
if UI_Target:FindFirstChild("WEYZ_UI") then
    UI_Target.WEYZ_UI:Destroy()
end

local sg = Instance.new("ScreenGui", UI_Target)
sg.Name = "WEYZ_UI"
sg.ResetOnSpawn = false

-- PANEL
local Main = Instance.new("Frame", sg)
Main.Size = UDim2.new(0, 220, 0, 90)
Main.Position = UDim2.new(0.5, -110, 0, -100)
